+    for step in key_steps:
+        if step in code:
+            print(f"  ✅ {step}")
+        else:
+            print(f"  ⚠️  {step}")
+    
+    # 6. 检查验证逻辑
+    validations = [
+        "epoch 1 ledger_info.block_number + 1",
+        "epoch 2 round 1 block.block_number",
