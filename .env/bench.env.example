# =============================================================================
# Gravity Benchmark Environment Configuration
# Copy this file to bench.env and fill in your values:
#   cp .env/bench.env.example .env/bench.env
# Then source it before running bench operations:
#   source .env/bench.env
# =============================================================================

# --- GCP Project ---
GCP_PROJECT="your-gcp-project"
GCP_ZONE="us-central1-a"

# --- Deploy Machine (Cluster Node) ---
DEPLOY_INSTANCE="your-deploy-instance-name"
DEPLOY_USER="your-user"
DEPLOY_SDK_DIR="/home/your-user/gravity-sdk"

# --- Bench Machine (Pressure/Stress) ---
BENCH_INSTANCE="your-bench-instance-name"
BENCH_USER="your-user"
BENCH_DIR="/home/your-user/gravity_bench"

# --- Resolve internal IPs from instance names ---
_resolve_ip() {
    gcloud compute instances describe "$1" \
        --project="$GCP_PROJECT" --zone="$GCP_ZONE" \
        --format="get(networkInterfaces[0].networkIP)" 2>/dev/null
}

DEPLOY_INTERNAL_IP="$(_resolve_ip "$DEPLOY_INSTANCE")"
BENCH_INTERNAL_IP="$(_resolve_ip "$BENCH_INSTANCE")"

if [ -z "$DEPLOY_INTERNAL_IP" ]; then
    echo "[WARN] Could not resolve IP for $DEPLOY_INSTANCE — is it running?"
fi

# --- RPC ---
RPC_PORT="8545"
RPC_URL="http://${DEPLOY_INTERNAL_IP}:${RPC_PORT}"

# --- Chain ---
CHAIN_ID="1337"

# --- Faucet ---
FAUCET_PRIVATE_KEY="your-faucet-private-key"
FAUCET_NUM_ACCOUNTS="100000"
FAUCET_ETH_BALANCE="1000000000000000000"

# --- Bench Parameters ---
BENCH_TARGET_TPS="20000"
BENCH_NUM_TOKENS="2"
BENCH_NUM_SENDERS="1000"
BENCH_MAX_POOL_SIZE="10000"
BENCH_DURATION_SECS="300"

# =============================================================================
# Helper: SSH command prefix (handles non-login shell PATH issues)
# Usage: $SSH_DEPLOY "your command here"
#        $SSH_BENCH "your command here"
# =============================================================================
SSH_CMD_PREFIX="source \$HOME/.cargo/env && export PATH=\$HOME/.foundry/bin:\$HOME/.local/bin:\$PATH"
SSH_DEPLOY="gcloud compute ssh ${DEPLOY_USER}@${DEPLOY_INSTANCE} --project=${GCP_PROJECT} --zone=${GCP_ZONE} --tunnel-through-iap --command"
SSH_BENCH="gcloud compute ssh ${BENCH_USER}@${BENCH_INSTANCE} --project=${GCP_PROJECT} --zone=${GCP_ZONE} --tunnel-through-iap --command"
