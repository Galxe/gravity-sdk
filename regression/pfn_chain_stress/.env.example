# Copy to .env and edit. Loaded by run.sh.

# Bench parameters.
BENCH_DURATION_SECS=120
BENCH_TARGET_TPS=8000
BENCH_NUM_SENDERS=1500
BENCH_NUM_ACCOUNTS=10000

# Reserved cores (top of the cpuset range) for bench + system processes
# when run.sh is invoked with --cpuset. Default 6.
# BENCH_RESERVE=6

# Logging.
RUST_LOG=info
RUST_LOG_BENCH=info
